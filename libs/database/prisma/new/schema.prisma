model RewardPunishRule {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(255)
  type          RewardPunishType
  workShift     String?        @db.VarChar(50)
  maxViolations Int            @default(5)
  isActive      Boolean        @default(true)
  resetCycle    ResetCycle     @default(MONTHLY)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  severities    RuleSeverity[]
  violations    StaffViolation[]
}

model RuleSeverity {
  id               Int            @id @default(autoincrement())
  ruleId           Int
  occurrenceNumber Int
  actionType       RuleActionType
  amount           Decimal?       @db.Decimal(12, 0)
  
  rule             RewardPunishRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model StaffViolation {
  id               Int      @id @default(autoincrement())
  staffId          Int
  ruleId           Int
  violationDate    DateTime @default(now())
  occurrenceNumber Int
  amount           Decimal? @db.Decimal(12, 0)
  note             String?  @db.Text
  
  rule             RewardPunishRule @relation(fields: [ruleId], references: [id])
  staff            Staff            @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([ruleId])
  @@index([violationDate])
}

enum RewardPunishType {
  REWARD
  PUNISH
}

enum RuleActionType {
  WARNING
  MONEY
  DISMISSAL
}

enum ResetCycle {
  DAILY
  MONTHLY
  QUARTERLY
  YEARLY
  NEVER
}

