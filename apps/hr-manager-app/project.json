{
  "name": "hr-manager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/hr-manager-app/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "apps/hr-manager-app/src/**/*.{ts,tsx}"
        ],
        "maxWarnings": -1
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/hr-manager"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "hr-manager:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "hr-manager:build:development"
        },
        "production": {
          "buildTarget": "hr-manager:build:production"
        }
      }
    }
  }
}
