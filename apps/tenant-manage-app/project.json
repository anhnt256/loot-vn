{
  "name": "tenant-manage",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/tenant-manage-app/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "apps/tenant-manage-app/src/**/*.{ts,tsx}"
        ],
        "maxWarnings": -1
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/tenant-manage"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "tenant-manage:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "tenant-manage:build:development"
        },
        "production": {
          "buildTarget": "tenant-manage:build:production"
        }
      }
    },
    "preview": {
      "executor": "@nx/vite:preview",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "tenant-manage:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "tenant-manage:build:development"
        },
        "production": {
          "buildTarget": "tenant-manage:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "../../coverage/apps/tenant-manage-app"
      }
    }
  }
}
